{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A logistics project delivery",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "number" },
        "imagePosition": { "type": "number" },
        "imageFit": { "type": "string", "enum": ["cover", "contain"] },
        "content": { "type": "string" }
      },
      "required": ["title", "description", "category", "createdAt"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of logistics projects"
    }
  }
}
